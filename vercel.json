{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/applywizz-api/:path*",
      "destination": "https://applywizz-5i8qccsfs-applywizz-tech-vercels-projects.vercel.app/api/:path*"
    },
    {
      "source": "/proxy-s3/:path*",
      "destination": "https://applywizz-prod.s3.us-east-2.amazonaws.com/:path*"
    },
    {
      "source": "/proxy-vercel-blob/:path*",
      "destination": "https://public.blob.vercel-storage.com/:path*"
    }
  ],
  "routes": [
    {
      "src": "/api/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/api/proxy-applywizz",
      "dest": "/api/proxy-applywizz.js"
    },
    {
      "src": "/api/generate-introduction",
      "dest": "/api/generate-introduction.js"
    },
    {
      "src": "/api/send-otp",
      "dest": "/api/send-otp.js"
    },
    {
      "src": "/api/send-credentials",
      "dest": "/api/send-credentials.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}